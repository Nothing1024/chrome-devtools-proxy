{
  "name": "chrome-devtools-proxy",
  "version": "1.0.0",
  "description": "MCP proxy that routes Chrome DevTools tool calls to multiple browser targets and coordinates with a separately installed AI tab-group extension",
  "type": "module",
  "main": "index.js",
  "bin": {
    "chrome-devtools-proxy": "./index.js"
  },
  "files": [
    "index.js",
    "targets.json"
  ],
  "scripts": {
    "check": "node --check index.js",
    "pack:dry-run": "npm pack --dry-run"
  },
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=23"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "chrome-devtools-mcp": "1.5.0"
  }
}
